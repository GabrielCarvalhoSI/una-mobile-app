PORT=3000

# Supabase — obter em: Dashboard → Project Settings → API
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# CORS — origens permitidas separadas por vírgula (deixe em branco para permitir todas em dev)
# Exemplo produção: CORS_ORIGINS=https://una.vercel.app,https://una-admin.vercel.app
CORS_ORIGINS=
