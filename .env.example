# Supabase — obter em: Dashboard → Project Settings → API
# ATENÇÃO: prefixo EXPO_PUBLIC_ (não NEXT_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# URL do backend una-backend rodando localmente
# Android Emulator: usar 10.0.2.2 no lugar de localhost
# Device físico: usar o IP da máquina na rede local (ex: 192.168.x.x)
EXPO_PUBLIC_API_URL=http://localhost:3000
